{
  "manifest_version": 3,
  "name": "Daily Blessing — Verse & Shloka New Tab",
  "version": "1.0.0",
  "description": "Calm new tab with a daily Bible verse or Gita shloka and a prayer list. Christian, Hindu, or mix. Hindi & English. Ad-free, offline.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "daily-blessing@arvindvyas.dev",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
